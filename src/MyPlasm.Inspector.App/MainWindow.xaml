<Window x:Class="MyPlasm.Inspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPlasm Inspector"
        Width="900"
        Height="680"
        MinWidth="700"
        MinHeight="520"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock FontSize="28" FontWeight="Bold" Text="MyPlasm Inspector" />
            <TextBlock Margin="0,8,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="DarkGreen"
                       Text="APPLICATION STARTED SUCCESSFULLY" />
            <TextBlock Margin="0,8,0,0"
                       Text="PASSIVE RECEIVE ONLY — NO CONTROLLER COMMANDS OR TRANSMITS" />

            <Border Margin="0,22,0,0" Padding="16" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock x:Name="RenderingStatusText" FontWeight="SemiBold" />
                    <TextBlock x:Name="ArchitectureStatusText" Margin="0,6,0,0" />
                    <TextBlock x:Name="AllowlistStatusText" Margin="0,6,0,0" FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Startup log file" />
                    <TextBlock x:Name="LogFileLocationText" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,22,0,0">
                <Button x:Name="RunFakeEnumerationButton"
                        Padding="16,8"
                        Click="RunFakeEnumerationButton_Click"
                        Content="Run Fake Enumeration" />
                <Button x:Name="InspectD2xxDevicesButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="InspectD2xxDevicesButton_Click"
                        Content="Inspect D2XX Devices" />
                <Button x:Name="OpenExactDeviceButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="OpenExactDeviceButton_Click"
                        Content="Open Exact MyPlasm Device"
                        IsEnabled="False" />
            </WrapPanel>

            <WrapPanel Margin="0,12,0,0">
                <TextBlock VerticalAlignment="Center" Text="Duration (seconds, max 300):" />
                <TextBox x:Name="CaptureDurationTextBox" Margin="8,0,0,0" Width="55" Text="30" />
                <Button x:Name="StartCaptureButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="StartCaptureButton_Click"
                        Content="Start Passive Capture"
                        IsEnabled="False" />
                <Button x:Name="StopCaptureButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="StopCaptureButton_Click"
                        Content="Stop Capture"
                        IsEnabled="False" />
                <Button x:Name="CloseDeviceButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="CloseDeviceButton_Click"
                        Content="Close Device"
                        IsEnabled="False" />
                <Button x:Name="ExportDiagnosticPackageButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="ExportDiagnosticPackageButton_Click"
                        Content="Export Diagnostic Package"
                        IsEnabled="False" />
            </WrapPanel>

            <TextBlock x:Name="InspectionStatusText" Margin="0,18,0,0" Text="No transport has been created." />
            <TextBlock Text="PASSIVE RECEIVE ONLY — ZERO TRANSMITS" FontWeight="Bold" Foreground="DarkRed" Margin="0,8,0,0" />

            <Border Margin="0,14,0,0" Padding="14" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="Bold" Text="Selected exact device:" />
                    <TextBlock x:Name="SelectedDeviceText" Grid.Column="1" Margin="8,0,20,0" Text="None" />
                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Serial:" />
                    <TextBlock x:Name="SerialText" Grid.Column="3" Margin="8,0,0,0" Text="None" />
                    <TextBlock Grid.Row="1" FontWeight="Bold" Text="Device state:" />
                    <TextBlock x:Name="DeviceStateText" Grid.Row="1" Grid.Column="1" Margin="8,0,20,0" Text="Closed" />
                    <TextBlock Grid.Row="1" Grid.Column="2" FontWeight="Bold" Text="Driver version:" />
                    <TextBlock x:Name="DriverVersionText" Grid.Row="1" Grid.Column="3" Margin="8,0,0,0" Text="Unavailable" />
                    <TextBlock Grid.Row="2" FontWeight="Bold" Text="Capture state:" />
                    <TextBlock x:Name="CaptureStateText" Grid.Row="2" Grid.Column="1" Margin="8,0,20,0" Text="Idle" />
                    <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="Bold" Text="Elapsed:" />
                    <TextBlock x:Name="ElapsedText" Grid.Row="2" Grid.Column="3" Margin="8,0,0,0" Text="00:00:00" />
                    <TextBlock Grid.Row="3" FontWeight="Bold" Text="Queue depth:" />
                    <TextBlock x:Name="QueueDepthText" Grid.Row="3" Grid.Column="1" Margin="8,0,20,0" Text="0" />
                    <TextBlock Grid.Row="3" Grid.Column="2" FontWeight="Bold" Text="Last D2XX status:" />
                    <TextBlock x:Name="LastStatusText" Grid.Row="3" Grid.Column="3" Margin="8,0,0,0" Text="Ok" />
                    <TextBlock Grid.Row="4" FontWeight="Bold" Text="Bytes received:" />
                    <TextBlock x:Name="BytesReceivedText" Grid.Row="4" Grid.Column="1" Margin="8,0,20,0" Text="0" />
                    <TextBlock Grid.Row="4" Grid.Column="2" FontWeight="Bold" Text="Chunks received:" />
                    <TextBlock x:Name="ChunksReceivedText" Grid.Row="4" Grid.Column="3" Margin="8,0,0,0" Text="0" />
                    <TextBlock Grid.Row="5" FontWeight="Bold" Text="Transmit count:" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="8,0,20,0" Text="0" />
                    <TextBlock Grid.Row="5" Grid.Column="2" FontWeight="Bold" Text="Production allowlist:" />
                    <TextBlock Grid.Row="5" Grid.Column="3" Margin="8,0,0,0" Text="Empty (0)" />
                </Grid>
            </Border>

            <ListBox x:Name="EventLog" Margin="0,10,0,0" Height="170" />
        </StackPanel>
    </ScrollViewer>
</Window>
