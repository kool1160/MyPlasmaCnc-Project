<Window x:Class="MyPlasm.Inspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPlasm Inspector"
        Width="760"
        Height="540"
        MinWidth="620"
        MinHeight="420"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock FontSize="28" FontWeight="Bold" Text="MyPlasm Inspector" />
            <TextBlock Margin="0,8,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="DarkGreen"
                       Text="APPLICATION STARTED SUCCESSFULLY" />
            <TextBlock Margin="0,8,0,0"
                       Text="DEVICE ENUMERATION ONLY — NO CONTROLLER COMMANDS" />

            <Border Margin="0,22,0,0" Padding="16" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock x:Name="RenderingStatusText" FontWeight="SemiBold" />
                    <TextBlock x:Name="ArchitectureStatusText" Margin="0,6,0,0" />
                    <TextBlock x:Name="AllowlistStatusText" Margin="0,6,0,0" FontWeight="SemiBold" />
                    <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Startup log file" />
                    <TextBlock x:Name="LogFileLocationText" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Margin="0,22,0,0" Orientation="Horizontal">
                <Button x:Name="RunFakeEnumerationButton"
                        Padding="16,8"
                        Click="RunFakeEnumerationButton_Click"
                        Content="Run Fake Enumeration" />
                <Button x:Name="InspectD2xxDevicesButton"
                        Margin="12,0,0,0"
                        Padding="16,8"
                        Click="InspectD2xxDevicesButton_Click"
                        Content="Inspect D2XX Devices" />
            </StackPanel>

            <TextBlock x:Name="InspectionStatusText" Margin="0,18,0,0" Text="No transport has been created." />
            <ListBox x:Name="EventLog" Margin="0,10,0,0" Height="170" />
        </StackPanel>
    </ScrollViewer>
</Window>
