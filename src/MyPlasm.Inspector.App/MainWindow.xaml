<Window x:Class="MyPlasm.Inspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPlasm Inspector"
        Width="1080"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        Background="#0B1020"
        Foreground="#F4F7FB"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="Bold" Text="MyPlasm Inspector" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#AEB9CC"
                           FontSize="15"
                           Text="Read-only Windows application foundation" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="16,9"
                    CornerRadius="18"
                    Background="#183A31"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1">
                <TextBlock Foreground="#7EF0B5"
                           FontWeight="Bold"
                           Text="DENY-ALL COMMAND POLICY ACTIVE" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock Foreground="#8FA0BB" Text="TRANSPORT MODE" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Fake FTDI — no hardware access" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock Foreground="#8FA0BB" Text="TRANSMIT ALLOWLIST" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="0 commands — every payload rejected" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="105" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock FontSize="19" FontWeight="SemiBold" Text="FTDI devices (simulated)" />
                    <TextBlock x:Name="ConnectionStatusText"
                               DockPanel.Dock="Right"
                               Foreground="#8FA0BB"
                               Text="Disconnected" />
                </DockPanel>

                <DataGrid x:Name="DevicesGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          Background="#10182A"
                          Foreground="#F4F7FB"
                          RowBackground="#10182A"
                          AlternatingRowBackground="#131D31"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="2*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding DeviceType}" Width="*" />
                        <DataGridTextColumn Header="VID" Binding="{Binding VendorIdDisplay}" Width="*" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProductIdDisplay}" Width="*" />
                        <DataGridCheckBoxColumn Header="MyPlasm" Binding="{Binding IsMyPlasmController}" Width="*" />
                        <DataGridCheckBoxColumn Header="Open" Binding="{Binding IsOpen}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Margin="0,16,0,14" Orientation="Horizontal">
                    <Button Click="RefreshButton_Click" Content="Refresh fake devices" />
                    <Button Click="ConnectButton_Click" Content="Connect selected target" />
                    <Button Click="DisconnectButton_Click" Content="Disconnect" />
                </StackPanel>

                <ListBox x:Name="EventLog"
                         Grid.Row="3"
                         Background="#0B1020"
                         Foreground="#CBD5E5"
                         BorderThickness="0" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Foreground="#7F8EA8"
                   Text="No native D2XX library is loaded. No controller command can be sent from this shell." />
    </Grid>
</Window>
