<Window x:Class="MyPlasm.Inspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPlasm Inspector"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        Background="#0B1020"
        Foreground="#F4F7FB"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="Bold" Text="MyPlasm Inspector" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#AEB9CC"
                           FontSize="15"
                           Text="DEVICE ENUMERATION ONLY — NO CONTROLLER COMMANDS" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="16,9"
                    CornerRadius="18"
                    Background="#183A31"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1">
                <TextBlock Foreground="#7EF0B5"
                           FontWeight="Bold"
                           Text="PRODUCTION ALLOWLIST: EMPTY" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock Foreground="#8FA0BB" Text="TRANSPORT MODE" />
                    <ComboBox x:Name="TransportSelector"
                              Margin="0,7,0,0"
                              Padding="8,5"
                              SelectedIndex="0"
                              SelectionChanged="TransportSelector_SelectionChanged">
                        <ComboBoxItem Tag="Fake" Content="Fake transport" />
                        <ComboBoxItem Tag="D2xx" Content="D2XX inspection transport" />
                    </ComboBox>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock Foreground="#8FA0BB" Text="NATIVE LIBRARY" />
                    <TextBlock x:Name="LibraryStatusText"
                               Margin="0,7,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Not loaded in fake mode" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="18" CornerRadius="10" Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock x:Name="DeviceListHeading"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Text="FTDI devices (simulated)" />
                    <TextBlock x:Name="ConnectionStatusText"
                               DockPanel.Dock="Right"
                               Foreground="#8FA0BB"
                               Text="Enumeration idle" />
                </DockPanel>

                <DataGrid x:Name="DevicesGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          Background="#10182A"
                          Foreground="#F4F7FB"
                          RowBackground="#10182A"
                          AlternatingRowBackground="#131D31"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="0.7*" />
                        <DataGridTextColumn Header="Location" Binding="{Binding LocationIdDisplay}" Width="1.2*" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="2*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding DeviceType}" Width="1.7*" />
                        <DataGridTextColumn Header="VID" Binding="{Binding VendorIdDisplay}" Width="*" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProductIdDisplay}" Width="*" />
                        <DataGridCheckBoxColumn Header="Candidate" Binding="{Binding IsMyPlasmController}" Width="*" />
                        <DataGridCheckBoxColumn Header="Open" Binding="{Binding IsOpen}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Margin="0,16,0,14" Orientation="Horizontal">
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click" Content="Enumerate devices" />
                    <Button x:Name="ConnectButton" Click="ConnectButton_Click" Content="Open fake target" />
                    <Button x:Name="DisconnectButton" Click="DisconnectButton_Click" Content="Close fake target" />
                </StackPanel>

                <ListBox x:Name="EventLog"
                         Grid.Row="3"
                         Background="#0B1020"
                         Foreground="#CBD5E5"
                         BorderThickness="0" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Foreground="#7F8EA8"
                   Text="D2XX mode lists device metadata only. It cannot open, read, configure, or write a device." />
    </Grid>
</Window>
